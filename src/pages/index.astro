---
import BaseHead from '@/components/BaseHead.astro'
import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'
import { SITE_TITLE, SITE_DESCRIPTION } from '@/consts'
import { getCollection } from 'astro:content'
import BentoCard from '@/components/BentoCard.astro'
import SectionDivider from '@/components/SectionDivider.astro'
import Starburst from '@/components/Starburst.astro'
import Backdrop from '@/components/Backdrop.astro'

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 9) // Limit to 9 posts for the home page grid
---

<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body
    class="bg-background text-foreground antialiased selection:bg-primary selection:text-background"
  >
    <div class="noise-overlay"></div>
    <Backdrop />
    <Header />
    <main>
      <section
        class="min-h-screen flex flex-col justify-center relative overflow-hidden"
      >
        <!-- Ambient atomic starbursts -->
        <Starburst
          class="pointer-events-none select-none absolute -top-24 -right-24 h-[34rem] w-[34rem] text-gold/15 animate-spin-slow"
        />
        <Starburst
          class="pointer-events-none select-none absolute bottom-10 -left-28 h-72 w-72 text-accent/10"
        />

        <div
          class="container relative flex flex-col justify-center min-h-screen"
        >
          <!-- Center Headline -->
          <div class="relative z-10">
            <h1
              class="font-display text-[11vw] lg:text-[8.5rem] leading-[0.95] tracking-tight"
            >
              Brian<br />
              <span class="text-primary">Kimball</span>
            </h1>

            <div class="mt-10 flex items-center gap-4 max-w-lg">
              <span class="h-px flex-1 max-w-16 bg-gold/60"></span>
              <Starburst class="h-4 w-4 text-accent shrink-0" />
              <span class="h-px flex-1 bg-gold/60"></span>
            </div>

            <div
              class="mt-8 font-mono text-sm md:text-base tracking-[0.2em] text-foreground/70 max-w-lg"
            >
              SYSTEMS ENGINEER / DEVELOPER
              <span class="block text-accent mt-2 font-bold"
                >BUILDING FROM THE METAL UP</span
              >
            </div>
          </div>
        </div>
      </section>

      <SectionDivider />

      <!-- Bento Grid -->
      <section class="pb-24">
        <div class="container">
          <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-4 auto-rows-[minmax(240px,auto)]"
          >
            {
              posts.map((post, index) => {
                let colSpan = 'lg:col-span-3'
                let rowSpan = ''

                if (index === 0) {
                  colSpan = 'md:col-span-2 lg:col-span-6'
                  rowSpan = 'row-span-2'
                } else if (index === 1 || index === 2) {
                  colSpan = 'md:col-span-1 lg:col-span-3'
                }

                return (
                  <BentoCard
                    post={post}
                    class={`${colSpan} ${rowSpan}`}
                    featured={index === 0}
                  />
                )
              })
            }
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
