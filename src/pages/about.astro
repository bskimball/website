---
import BaseHead from '@/components/BaseHead.astro'
import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'
import { Image } from 'astro:assets'
import meImg from '../assets/me_website_2026.png'
import Backdrop from '@/components/Backdrop.astro'
import { SITE_URL, AUTHOR_NAME } from '@/consts'

const aboutDescription =
  'Brian Kimball is a Systems Engineer and Developer based in Delaware. He writes about IBM i modernization, full-stack development, network infrastructure, and building resilient systems from the metal up.'

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: AUTHOR_NAME,
  url: `${SITE_URL}/about`,
  image: `${SITE_URL}/static/images/avatar.png`,
  jobTitle: 'Systems Engineer / Developer',
  description: aboutDescription,
  sameAs: [
    'https://github.com/bskimball',
  ],
  worksFor: {
    '@type': 'Organization',
    name: 'BDK Inc.',
  },
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: SITE_URL,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'About',
      item: `${SITE_URL}/about`,
    },
  ],
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="About" description={aboutDescription} />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(personSchema)}
    />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbSchema)}
    />
  </head>
  <body
    class="bg-background text-foreground antialiased selection:bg-primary selection:text-background"
  >
    <div class="noise-overlay"></div>
    <Backdrop />
    <Header />
    <main class="container py-20">
      <div class="flex flex-col gap-12">
        <h1
          class="leading-tight text-7xl md:text-8xl font-display animate-in fade-in slide-in-from-bottom-2 fill-mode-both duration-1000"
        >
          About / Me
        </h1>
        <div
          class="grid lg:grid-cols-5 gap-16 animate-in fade-in slide-in-from-bottom-2 fill-mode-both duration-1000 delay-150"
        >
          <section
            class="col-span-3 prose prose-lg max-w-none text-foreground/80"
          >
            <p>
              Brian Kimball operates at the intersection of infrastructure and
              code. With a deep foundation in both networking and software
              development, he brings a holistic "systems thinking" approach to
              every project. His background spans Managed Service Providers
              (MSP) and Cloud Service Providers (CSP), where he honed the
              ability to build resilient, scalable solutions from the metal up.
            </p>
            <p>
              Originally trained in graphic design and web development, Brian's
              career trajectory pivoted into the core of IT operations. He
              advanced from helpdesk support to Systems Engineer, eventually
              leading the technical architecture for a burgeoning cloud services
              division. This hybrid path has forged a unique skillset: he
              doesn't just write the application; he understands the network it
              traverses and the hardware it lives on. When Brian says
              "full-stack," he means he racked the servers, configured the
              VLANs, and <em>then</em> deployed the application.
            </p>
            <p>
              This portfolio serves as a catalog of his open-source
              contributions and technical experiments. Based in Delaware, Brian
              balances his engineering pursuits with family life as a husband
              and father of three. When not deploying code or configuring
              switches, he can be found cheering for the Baltimore Ravens and
              Orioles or diving back into the Star Wars galaxy.
            </p>
          </section>
          <aside
            class="col-span-2 flex flex-col items-center lg:items-end gap-8"
          >
            <div
              class="transition-all duration-500 border-2 border-border p-2 bg-card rounded-full"
            >
              <Image
                src={meImg}
                alt="Brian Kimball portrait"
                class="w-64 h-auto aspect-square object-cover rounded-full"
                quality="max"
                format="png"
                widths={[256, 512, 1024]}
                sizes="256px"
              />
            </div>
            <div class="font-mono text-sm tracking-widest text-primary">
              Systems Engineer / Developer
            </div>
          </aside>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
