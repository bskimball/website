---
import BaseHead from '@/components/BaseHead.astro'
import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'
import { getCollection } from 'astro:content'
import Backdrop from '@/components/Backdrop.astro'
import { SITE_URL } from '@/consts'

const tags = await getCollection('tags')

const tagsDescription =
  'Browse articles by topic — IBM i, full-stack development, infrastructure, design systems, and more.'

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: SITE_URL,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Tags',
      item: `${SITE_URL}/tags`,
    },
  ],
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Tags" description={tagsDescription} />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbSchema)}
    />
  </head>
  <body
    class="bg-background text-foreground antialiased selection:bg-primary selection:text-background"
  >
    <div class="noise-overlay"></div>
    <Backdrop />
    <Header />
    <main class="container py-20">
      <div class="flex flex-col gap-12">
        <h1
          class="leading-tight text-7xl md:text-8xl font-display animate-in fade-in slide-in-from-bottom-2 fill-mode-both duration-1000"
        >
          Index / Tags
        </h1>
        <section class="flex flex-wrap gap-4">
          {
            tags.map((tag, index) => (
              <a
                href={`/${tag.collection}/${tag.id}`}
                class="animate-in fade-in slide-in-from-bottom-2 fill-mode-both duration-500 border border-foreground/20 px-4 py-2 hover:bg-primary hover:text-background hover:border-background transition-colors font-mono text-lg rounded-full"
                style={{ animationDelay: `${index * 50}ms` }}
              >
                {tag.data.name}
              </a>
            ))
          }
        </section>
      </div>
    </main>
    <Footer />
  </body>
</html>
