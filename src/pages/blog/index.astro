---
import BaseHead from '../../components/BaseHead.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import { getCollection } from 'astro:content'
import { SITE_URL } from '../../consts'

import BentoCard from '../../components/BentoCard.astro'
import Backdrop from '../../components/Backdrop.astro'

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())

const blogDescription =
  'Articles on IBM i modernization, full-stack development, network infrastructure, and systems engineering by Brian Kimball.'

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: SITE_URL,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Blog',
      item: `${SITE_URL}/blog`,
    },
  ],
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Blog" description={blogDescription} />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbSchema)}
    />
  </head>
  <body
    class="bg-background text-foreground antialiased selection:bg-primary selection:text-background"
  >
    <div class="noise-overlay"></div>
    <Backdrop />
    <Header />
    <main class="container py-20">
      <section class="flex flex-col gap-12">
        <div>
          <h1
            class="leading-tight text-7xl md:text-8xl font-display animate-in fade-in slide-in-from-bottom-2 fill-mode-both duration-1000"
          >
            Blog
          </h1>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {posts.map((post) => <BentoCard post={post} />)}
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
