---
// Global atomic backdrop — a subtle mid-century swirl behind all content,
// echoing the teal boomerang + gold orbital arc in the me_website_2026 art.
// Fixed and very low opacity so it reads as ambient texture, never noise.
// Sits at -z-10: above the page background color, beneath all content.
---

<div
  class="pointer-events-none fixed inset-0 -z-10 overflow-hidden select-none"
  aria-hidden="true"
>
  <svg
    class="absolute inset-0 h-full w-full"
    viewBox="0 0 1440 1024"
    preserveAspectRatio="xMidYMid slice"
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- Teal boomerang sweep -->
    <path
      d="M 40 230 C 360 40 800 340 1180 160"
      fill="none"
      stroke={`hsl(var(--primary) / 0.07)`}
      stroke-width="132"
      stroke-linecap="round"></path>

    <!-- Long gold orbital arcs -->
    <path
      d="M -140 740 C 380 820 1040 210 1620 400"
      fill="none"
      stroke={`hsl(var(--gold) / 0.16)`}
      stroke-width="3"></path>
    <path
      d="M -140 800 C 440 900 1080 280 1660 470"
      fill="none"
      stroke={`hsl(var(--gold) / 0.07)`}
      stroke-width="2"></path>

    <!-- Orbit body riding the arc -->
    <circle cx="1512" cy="372" r="7" fill={`hsl(var(--gold) / 0.2)`}></circle>
  </svg>
</div>
