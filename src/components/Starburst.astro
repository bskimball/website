---
// Atomic starburst — mid-century "sparkle" mark in the spirit of the
// me_website_2026 illustration: thin spikes that taper to sharp points,
// alternating long/short rays, a small core. Inherits `currentColor`, so
// color it on the parent (e.g. class="text-gold" / "text-accent").
//   dots: small "electron" balls capping every ray tip (on by default).
interface Props {
  class?: string
  dots?: boolean
}
const { class: className, dots = true } = Astro.props

const N = 16
const C = 50
const spikes = Array.from({ length: N }, (_, i) => {
  const a = (i * (360 / N) * Math.PI) / 180
  const long = i % 2 === 0
  const R = long ? 47 : 25
  const hw = long ? 2 : 1.3 // base half-width → thinner short rays
  const dx = Math.cos(a)
  const dy = Math.sin(a)
  const px = -Math.sin(a)
  const py = Math.cos(a)
  const tipX = C + R * dx
  const tipY = C + R * dy
  return {
    points: `${(C + hw * px).toFixed(2)},${(C + hw * py).toFixed(2)} ${tipX.toFixed(2)},${tipY.toFixed(2)} ${(C - hw * px).toFixed(2)},${(C - hw * py).toFixed(2)}`,
    long,
    tipX: tipX.toFixed(2),
    tipY: tipY.toFixed(2),
  }
})
---

<svg
  class={className}
  viewBox="0 0 100 100"
  fill="currentColor"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  {spikes.map((s) => <polygon points={s.points} />)}
  <circle cx="50" cy="50" r="3.2"></circle>
  {
    dots &&
      spikes.map((s) => (
        <circle cx={s.tipX} cy={s.tipY} r={s.long ? 2.5 : 1.7} />
      ))
  }
</svg>
