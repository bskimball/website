---
import Starburst from './Starburst.astro'
const today = new Date()
---

<footer
  class="bg-secondary pt-20 pb-64 border-t-2 border-primary/20 mt-20 relative overflow-hidden"
>
  <!-- Sky: warm sunset glow rising from the horizon + sputnik 'stars' -->
  <div class="absolute inset-0 pointer-events-none select-none">
    <div
      class="absolute inset-0"
      style="background: radial-gradient(72% 115% at 63% 100%, hsl(var(--footer-sun) / 0.4) 0%, hsl(var(--footer-sun) / 0.12) 42%, transparent 78%);"
    >
    </div>
    <Starburst class="absolute top-12 right-[14%] h-6 w-6 text-gold/40" />
    <Starburst class="absolute top-28 left-[18%] h-4 w-4 text-accent/30" />
    <Starburst class="absolute top-16 left-[52%] h-3 w-3 text-gold/30" />
    <Starburst class="absolute top-40 right-[36%] h-5 w-5 text-foreground/15" />
  </div>

  <!-- Googie skyline: a space-age city at dusk, anchored below the content -->
  <div
    class="absolute inset-x-0 bottom-0 h-64 pointer-events-none select-none"
  >
    <svg
      class="absolute inset-0 w-full h-full"
      viewBox="0 0 1200 300"
      preserveAspectRatio="xMidYMax slice"
      xmlns="http://www.w3.org/2000/svg"
    >
      <!-- Setting sun with retro banding -->
      <g>
        <circle cx="760" cy="250" r="82" fill={`hsl(var(--footer-sun))`}
        ></circle>
        <g fill={`hsl(var(--secondary))`}>
          <rect x="648" y="240" width="224" height="6"></rect>
          <rect x="648" y="226" width="224" height="7"></rect>
          <rect x="648" y="210" width="224" height="9"></rect>
          <rect x="648" y="192" width="224" height="11"></rect>
        </g>
      </g>

      <!-- Back layer: far towers + haze (faintest) -->
      <g fill={`hsl(var(--footer-landscape-1))`}>
        <rect x="64" y="120" width="42" height="180"></rect>
        <rect x="118" y="150" width="30" height="150"></rect>
        <rect x="300" y="150" width="84" height="150"></rect>
        <path d="M300,150 a42,28 0 0 1 84,0 Z"></path>
        <rect x="980" y="110" width="46" height="190"></rect>
        <rect x="1036" y="144" width="34" height="156"></rect>
      </g>

      <!-- Mid layer: monorail + buildings -->
      <g fill={`hsl(var(--footer-landscape-2))`}>
        <!-- pylons -->
        <path d="M198,300 L216,300 L210,226 L206,226 Z"></path>
        <path d="M618,300 L636,300 L630,226 L626,226 Z"></path>
        <path d="M1018,300 L1036,300 L1030,226 L1026,226 Z"></path>
        <!-- beam -->
        <rect x="-40" y="224" width="1280" height="11" rx="5"></rect>
        <!-- streamlined monorail car -->
        <rect x="430" y="206" width="146" height="20" rx="10"></rect>
      </g>

      <!-- Front layer: Googie city (darkest, nearest) -->
      <g fill={`hsl(var(--footer-landscape-3))`}>
        <!-- ground -->
        <rect x="0" y="252" width="1200" height="60"></rect>

        <!-- Space Needle -->
        <rect x="156" y="96" width="7" height="156"></rect>
        <ellipse cx="159" cy="96" rx="30" ry="10"></ellipse>
        <rect x="157" y="72" width="4" height="24"></rect>
        <circle cx="159" cy="68" r="3.5"></circle>

        <!-- Dome building -->
        <rect x="232" y="198" width="86" height="54"></rect>
        <path d="M232,198 a43,28 0 0 1 86,0 Z"></path>
        <rect x="273" y="172" width="4" height="26"></rect>

        <!-- Butterfly-roof coffee shop -->
        <rect x="366" y="202" width="112" height="50"></rect>
        <path d="M354,194 L422,214 L490,194 L490,204 L422,224 L354,204 Z"
        ></path>

        <!-- Theme Building arches (hero) -->
        <path
          fill-rule="evenodd"
          d="M556,252 Q566,118 660,114 Q754,118 764,252 L744,252 Q736,148 660,144 Q584,148 576,252 Z"
        ></path>
        <ellipse cx="660" cy="118" rx="44" ry="13"></ellipse>
        <rect x="657" y="96" width="6" height="22"></rect>
        <circle cx="660" cy="92" r="3.5"></circle>

        <!-- Stepped ziggurat tower -->
        <rect x="820" y="170" width="58" height="82"></rect>
        <rect x="830" y="150" width="38" height="20"></rect>
        <rect x="842" y="132" width="16" height="18"></rect>

        <!-- Dome cluster -->
        <path d="M906,252 a40,40 0 0 1 80,0 Z"></path>
        <path d="M996,252 a26,26 0 0 1 52,0 Z"></path>
        <rect x="1060" y="204" width="32" height="48"></rect>

        <!-- Antenna tower -->
        <rect x="1126" y="120" width="9" height="132"></rect>
        <circle cx="1130" cy="110" r="4"></circle>
        <rect x="1128" y="110" width="4" height="12"></rect>
      </g>
    </svg>
  </div>

  <div class="container relative z-10">
    <div class="mb-20 flex items-end gap-6">
      <a
        href="mailto:briankimball1982@gmail.com"
        class="text-6xl md:text-8xl font-display text-foreground hover:text-primary transition-colors duration-300 tracking-tight leading-none"
      >
        Connect
      </a>
      <Starburst class="mb-2 h-10 w-10 shrink-0 text-accent" />
    </div>

    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-12 font-mono text-xs tracking-widest text-foreground/60"
    >
      <div class="flex flex-col gap-4">
        <span class="text-primary mb-2">Navigation</span>
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <a href="/blog" class="hover:text-primary transition-colors">Blog</a>
        <a href="/about" class="hover:text-primary transition-colors">About</a>
        <a href="/tags" class="hover:text-primary transition-colors">Tags</a>
      </div>
      <div class="flex flex-col gap-4">
        <span class="text-primary mb-2">Social</span>
        <div class="flex flex-col gap-4">
          <a
            href="https://github.com/bskimball"
            target="_blank"
            class="hover:text-primary transition-colors">GitHub</a
          >
          <a
            href="https://www.linkedin.com/in/brian-kimball-0499678a/"
            target="_blank"
            class="hover:text-primary transition-colors">LinkedIn</a
          >
          <a
            href="https://twitter.com/_BrianKimball"
            target="_blank"
            class="hover:text-primary transition-colors">Twitter</a
          >
        </div>
      </div>
      <div class="flex flex-col gap-4">
        <span class="text-primary mb-2">Legal</span>
        <span>&copy; {today.getFullYear()} Brian Kimball</span>
        <span>All rights reserved</span>
      </div>
    </div>
  </div>
</footer>
