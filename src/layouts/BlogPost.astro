---
import { type CollectionEntry } from 'astro:content'
import { Image, getImage } from 'astro:assets'
import BaseHead from '@/components/BaseHead.astro'
import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'
import FormattedDate from '@/components/FormattedDate.astro'
import { FaArrowLeft } from 'react-icons/fa6'
import BlockAuthor from '../components/BlockAuthor.astro'
import Backdrop from '@/components/Backdrop.astro'
import { SITE_URL, AUTHOR_NAME } from '@/consts'

type RelatedPost = {
  id: string
  data: Pick<
    CollectionEntry<'blog'>['data'],
    'title' | 'description' | 'pubDate'
  >
}

type Props = CollectionEntry<'blog'>['data'] & {
  relatedPosts?: RelatedPost[]
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroImageOptimized,
  fullImage,
  tags,
  relatedPosts = [],
} = Astro.props

const tagStrings = tags?.map((t) => (typeof t === 'object' ? t.id : t)) ?? []
const canonicalPostUrl = new URL(Astro.url.pathname, SITE_URL).toString()

let ogImagePath = heroImage
let ogImageWidth = 1200
let ogImageHeight = 630

if (heroImageOptimized) {
  const optimizedOg = await getImage({
    src: heroImageOptimized,
    width: 1200,
    format: 'jpg',
  })
  ogImagePath = optimizedOg.src
  ogImageWidth = optimizedOg.attributes.width ?? 1200
  ogImageHeight = optimizedOg.attributes.height ?? 630
}

const imageUrl = ogImagePath
  ? new URL(ogImagePath, SITE_URL).toString()
  : undefined

// JSON-LD structured data
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  image: imageUrl,
  url: canonicalPostUrl,
  datePublished: pubDate ? new Date(pubDate).toISOString() : undefined,
  dateModified: updatedDate
    ? new Date(updatedDate).toISOString()
    : pubDate
      ? new Date(pubDate).toISOString()
      : undefined,
  author: {
    '@type': 'Person',
    name: AUTHOR_NAME,
    url: `${SITE_URL}/about`,
  },
  publisher: {
    '@type': 'Person',
    name: AUTHOR_NAME,
    url: SITE_URL,
  },
  keywords: tagStrings.join(', '),
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: SITE_URL,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Blog',
      item: `${SITE_URL}/blog`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
      item: canonicalPostUrl,
    },
  ],
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={ogImagePath}
      imageWidth={ogImageWidth}
      imageHeight={ogImageHeight}
      type="article"
      pubDate={pubDate ? new Date(pubDate) : undefined}
      updatedDate={updatedDate ? new Date(updatedDate) : undefined}
      tags={tagStrings}
      author={AUTHOR_NAME}
    />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(articleSchema)}
    />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbSchema)}
    />
  </head>

  <body
    class="bg-background text-foreground antialiased selection:bg-primary selection:text-background"
  >
    <div class="noise-overlay"></div>
    <Backdrop />
    <Header />
    <main class="container py-12 lg:py-20">
      <article>
        <div class="flex flex-col gap-12">
          <!-- Header Section -->
          <div class="flex flex-col gap-8 border-b border-border pb-12">
            <div class="flex flex-col gap-6">
              <a
                href="/blog"
                class="w-fit flex gap-2 items-center font-mono text-xs tracking-widest text-primary/70 hover:text-primary transition-colors no-underline"
              >
                <FaArrowLeft /><span>Back to Index</span>
              </a>

              <h1
                class="font-serif text-5xl lg:text-7xl leading-none text-foreground"
              >
                {title}
              </h1>
            </div>

            <div
              class="flex flex-wrap items-center gap-6 font-mono text-xs tracking-widest text-foreground/60"
            >
              {
                pubDate && (
                  <div class="flex items-center gap-2">
                    <span class="text-primary">Date:</span>
                    <FormattedDate date={pubDate} />
                  </div>
                )
              }
              {
                updatedDate && (
                  <div class="flex items-center gap-2">
                    <span class="text-primary">Updated:</span>
                    <FormattedDate date={updatedDate} />
                  </div>
                )
              }
            </div>
          </div>

          <div class="grid lg:grid-cols-12 gap-12 lg:gap-24">
            <!-- Main Content -->
            <section
              class="min-w-0 lg:col-span-8 prose prose-lg max-w-none prose-headings:font-serif prose-headings:font-normal prose-a:text-primary prose-a:no-underline hover:prose-a:text-primary/80 prose-blockquote:border-l-primary prose-img:rounded-xl prose-img:border-2 prose-img:border-border"
            >
              {
                heroImageOptimized ? (
                  <div class="mb-12 not-prose flex flex-col gap-4">
                    <Image
                      class="w-full h-auto"
                      src={heroImageOptimized}
                      width={1280}
                      height={720}
                      alt={`${title} — featured image`}
                    />
                    {fullImage && (
                      <div class="flex justify-end">
                        <a
                          href={fullImage}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="font-mono text-[10px] tracking-[0.2em] uppercase text-foreground/50 hover:text-primary transition-colors flex items-center gap-2 group"
                        >
                          <span class="w-8 h-[1px] bg-border group-hover:bg-primary/40 transition-colors" />
                          Download full image
                        </a>
                      </div>
                    )}
                  </div>
                ) : (
                  heroImage && (
                    <div class="mb-12 not-prose flex flex-col gap-4">
                      <Image
                        class="w-full h-auto"
                        src={heroImage}
                        width={1280}
                        height={720}
                        alt={`${title} — featured image`}
                      />
                      {fullImage && (
                        <div class="flex justify-end">
                          <a
                            href={fullImage}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="font-mono text-[10px] tracking-[0.2em] uppercase text-foreground/50 hover:text-primary transition-colors flex items-center gap-2 group"
                          >
                            <span class="w-8 h-[1px] bg-border group-hover:bg-primary/40 transition-colors" />
                            Download full image
                          </a>
                        </div>
                      )}
                    </div>
                  )
                )
              }
              <slot />
            </section>

            <!-- Sidebar -->
            <aside
              class="lg:col-span-4 flex flex-col gap-12 h-fit lg:sticky lg:top-32"
            >
              <div class="flex flex-col gap-8">
                <div>
                  <span
                    class="font-mono text-xs tracking-widest text-primary block mb-4"
                    >Author</span
                  >
                  <BlockAuthor />
                </div>

                {
                  tags && tags.length > 0 && (
                    <div>
                      <span class="font-mono text-xs tracking-widest text-primary block mb-4">
                        Tags
                      </span>
                      <div class="flex flex-wrap gap-2">
                        {tags.map((tag) => {
                          const tagId = typeof tag === 'object' ? tag.id : tag
                          return (
                            <a
                              href={`/tags/${tagId}`}
                              class="font-mono text-xs border border-foreground/20 px-3 py-1 hover:bg-primary hover:text-background hover:border-primary transition-colors no-underline rounded-full"
                            >
                              {tagId}
                            </a>
                          )
                        })}
                      </div>
                    </div>
                  )
                }
              </div>
            </aside>
          </div>

          {
            relatedPosts.length > 0 && (
              <section class="border-t border-border pt-12">
                <span class="font-mono text-xs tracking-widest text-primary block mb-6">
                  Related Posts
                </span>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                  {relatedPosts.map((post) => (
                    <a
                      href={`/blog/${post.id}`}
                      class="group flex flex-col gap-3 rounded-2xl border-2 border-border bg-card p-5 no-underline transition-colors hover:border-primary"
                    >
                      <div class="font-mono text-[10px] tracking-widest text-foreground/50">
                        <FormattedDate date={post.data.pubDate} />
                      </div>
                      <h3 class="font-serif text-xl leading-tight text-foreground group-hover:text-primary transition-colors">
                        {post.data.title}
                      </h3>
                      <p class="line-clamp-2 text-sm text-foreground/70">
                        {post.data.description}
                      </p>
                    </a>
                  ))}
                </div>
              </section>
            )
          }
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
